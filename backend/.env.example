# SocialSync AI — Environment Variables
# Copy this to backend/.env and fill in values.

# ─── Backend Server ───────────────────────────────────────────────────────────
PORT=8000

# ─── CORS (comma-separated origins, use * for dev) ───────────────────────────
CORS_ORIGINS=*

# ─── Supabase (used by Flutter frontend) ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
